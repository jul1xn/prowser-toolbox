<%- include('../include/header.ejs') %>

    <div class="container mt-5">
        <div class="text-center mb-5">
            <h1 class="display-5 mb-3">Prowser Toolbox</h1>
            <p>On this page, you can view multiple tools on one page. No more switching sites constantly, everything on
                one page.</p>
            <a href="/toolbox" class="btn btn-primary big-btn">View all tools <ion-icon class="my-auto"
                    name="arrow-forward-outline"></ion-icon></a>
        </div>
        <div class="text-center mb-3">
            <h2 class="display-5">Populair tools</h2>
            <div class="row my-4 g-3">
                <% tools.forEach(tool=> { %>
                    <div class="col-12 col-sm-6 col-lg-3">
                        <a class="card toolCard h-100 text-decoration-none" href="/toolbox/<%= tool.url %>">
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title">
                                    <%= tool.name %>
                                </h5>
                                <p class="card-text">
                                    <%= tool.description %>
                                </p>
                                <div class="card-views mt-auto d-flex align-items-center">
                                    <ion-icon name="eye" class="me-1"></ion-icon>
                                    <%= tool.views %>
                                </div>
                            </div>
                        </a>
                    </div>
                    <% }); %>
            </div>
        </div>
    </div>

    <%- include('../include/footer.ejs') %>